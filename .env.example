# Django
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres
POSTGRES_DB=recap
POSTGRES_USER=recap_user
POSTGRES_PASSWORD=recap_pass
DATABASE_HOST=db
DATABASE_PORT=5432

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# OCR
OCR_MODE=fast
OCR_TASK_MAX_RETRIES=3
OCR_TASK_RETRY_BASE_SECONDS=2
OCR_TASK_RETRY_JITTER_SECONDS=1
